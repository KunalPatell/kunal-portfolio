# ─── Ask Kunal AI (all optional) ───────────────────────────────
# The assistant works WITHOUT any key using an offline knowledge base.
# Add a key to enable richer, generative answers. Gemini is tried first.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Contact form ──────────────────────────────────────────────
# Submissions are logged server-side by default. This is just the
# address shown/used as the intended recipient.
CONTACT_FORWARD_EMAIL=websitekunal@gmail.com

# ─── CORS (only matters for split local dev) ───────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
